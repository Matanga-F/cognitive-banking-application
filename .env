# ===========================================
# COGNITIVE BANKING - ENVIRONMENT VARIABLES
# ===========================================

# Profile - Use 'docker' since it depends on containers
SPRING_PROFILES_ACTIVE=docker

# ===========================================
# DATABASE (PostgreSQL)
# ===========================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cognitive_bank
DB_USERNAME=desta
DB_PASSWORD=C0g1n1tiv5B@nk

# Optional: Connection pool settings
DB_POOL_MAX_SIZE=20
DB_POOL_MIN_IDLE=5

# ===========================================
# REDIS CACHE
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass123
REDIS_DATABASE=0

# Optional: Redis pool settings
REDIS_POOL_MAX=10
REDIS_POOL_MAX_IDLE=5
REDIS_POOL_MIN_IDLE=2

# ===========================================
# APPLICATION
# ===========================================
SERVER_PORT=8080
LOG_LEVEL=DEBUG

# Context path is set in application.yml
SERVER_SERVLET_CONTEXT_PATH=/api/cognitive/bank

# ===========================================
# SECURITY (JWT) - FIXED
# ===========================================
# IMPORTANT: Change this in production!
JWT_SECRET=8iX+TfNHmbGXNxJ7MYlKY0QhTDB5F7DNCh0SPoI9hR0=
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ===========================================
# MONITORING (Optional - for Docker services)
# ===========================================
PGADMIN_DEFAULT_EMAIL=admin@cognitivebank.com
PGADMIN_DEFAULT_PASSWORD=admin123

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ===========================================
# SPRING BOOT SPECIFIC
# ===========================================
# Spring Boot 3.x
SPRING_CONFIG_IMPORT=optional:configtree:/run/secrets/

# Graceful shutdown
SPRING_LIFECYCLE_TIMEOUT_PER_SHUTDOWN_PHASE=30s

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=development
APP_VERSION=1.0.0